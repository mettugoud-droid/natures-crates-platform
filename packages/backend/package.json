{
  "name": "@natures-crates/backend",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/backend/src/index.js",
    "lint": "eslint src/",
    "db:migrate": "node-pg-migrate up",
    "db:migrate:down": "node-pg-migrate down",
    "db:seed": "tsx src/db/seeds/run.ts",
    "test": "vitest --run"
  },
  "dependencies": {
    "@natures-crates/shared": "*",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "pg-pool": "^3.7.0",
    "node-pg-migrate": "^7.0.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.0",
    "winston": "^3.13.0",
    "node-cron": "^3.0.3",
    "axios": "^1.7.0",
    "bottleneck": "^2.19.5",
    "p-retry": "^6.2.0",
    "@clerk/express": "^1.0.0",
    "openai": "^4.52.0",
    "@anthropic-ai/sdk": "^0.25.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/pg": "^8.11.6",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
