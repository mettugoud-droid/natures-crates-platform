# ===========================================
# Nature's Crates Platform - Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=natures_crates
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
DB_MAX_CONNECTIONS=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication (Clerk)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# AI Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-20250514

# Tier 1 - Official APIs
AMAZON_SP_API_KEY=
AMAZON_PA_API_KEY=
AMAZON_PA_API_SECRET=
AMAZON_PARTNER_TAG=
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=

# Tier 2 - Approved Data Providers
BRIGHT_DATA_API_KEY=
APIFY_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
KEEPA_API_KEY=
SEMRUSH_API_KEY=

# Tier 3 - Configurable Connectors
INDIAMART_CRM_KEY=
APIFY_INDIAMART_ACTOR_URL=

# Bright Data Collector IDs
BD_COLLECTOR_AMAZON_BS=
BD_COLLECTOR_AMAZON_MS=
BD_COLLECTOR_AMAZON_MW=
BD_COLLECTOR_AMAZON_NR=
BD_COLLECTOR_FLIPKART_BS=
BD_COLLECTOR_FLIPKART_TR=

# Compliance
DEFAULT_RATE_LIMIT=60
AUDIT_LOG_ENABLED=true
ROBOTS_TXT_RESPECT=true

# Scheduled Jobs
CRON_ENABLED=true
DAILY_SCAN_TIME=02:00

# Deployment
VERCEL_TOKEN=
RAILWAY_TOKEN=
